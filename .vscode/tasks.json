{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend - Install Dependencies",
      "type": "shell",
      "command": "npm",
      "args": ["install"],
      "cwd": "${workspaceFolder}/backend",
      "group": "build"
    },
    {
      "label": "Frontend - Install Dependencies",
      "type": "shell",
      "command": "npm",
      "args": ["install"],
      "cwd": "${workspaceFolder}/frontend",
      "group": "build"
    },
    {
      "label": "Backend - Dev Server",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "cwd": "${workspaceFolder}/backend",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*",
          "endsPattern": "running on"
        }
      },
      "group": "test"
    },
    {
      "label": "Frontend - Dev Server",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "cwd": "${workspaceFolder}/frontend",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*",
          "endsPattern": "Local:"
        }
      },
      "group": "test"
    },
    {
      "label": "Build - Frontend",
      "type": "shell",
      "command": "npm",
      "args": ["run", "build"],
      "cwd": "${workspaceFolder}/frontend",
      "group": "build"
    },
    {
      "label": "Build - Backend",
      "type": "shell",
      "command": "npm",
      "args": ["run", "build"],
      "cwd": "${workspaceFolder}/backend",
      "group": "build"
    },
    {
      "label": "Database - Load Schema",
      "type": "shell",
      "command": "psql",
      "args": [
        "-U",
        "postgres",
        "-d",
        "tap_track",
        "-f",
        "${workspaceFolder}/database/schema.sql"
      ],
      "group": "test"
    },
    {
      "label": "All - Install & Start",
      "type": "shell",
      "command": "npm",
      "args": ["run", "install-all"],
      "cwd": "${workspaceFolder}",
      "group": "build"
    }
  ]
}
